        <calculation class='tableau' formula='IF [Parameters].[Parameter 2] = &apos;Quantity&apos; THEN &apos;Quantity&apos;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Profit&apos; THEN &apos;Profit&apos;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Revenue&apos; THEN &apos;Revenue&apos;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Total Orders&apos; THEN &apos;Total Orders&apos;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Profit Margin&apos; THEN &apos;Profit Margin&apos;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Avg Sales Per Order&apos; THEN &apos;Avg Sales Per Order&apos;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Total Sales&apos; THEN &apos;Total Sales&apos;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Total Customers&apos; THEN &apos;Total Customers&apos;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Total Products&apos; THEN &apos;Total Products&apos;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Avg Age&apos; THEN &apos;Avg Age&apos;&#13;&#10;&#13;&#10;END' />

          <range granularity='1' max='15' min='1' />
        </column>
        <column caption='KPIs' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;Profit&quot;'>
          <calculation class='tableau' formula='&quot;Profit&quot;' />
          <members>
            <member value='&quot;Quantity&quot;' />
            <member value='&quot;Total Orders&quot;' />
            <member value='&quot;Total Sales&quot;' />
            <member value='&quot;Profit&quot;' />
            <member value='&quot;Profit Margin&quot;' />
            <member value='&quot;Avg Sales Per Order&quot;' />
            <member value='&quot;Revenue&quot;' />
            <member value='&quot;Total Customers&quot;' />
            <member value='&quot;Avg Age&quot;' />
            <member value='&quot;Total Products&quot;' />

      <aliases enabled='yes' />
      <column caption='Control KPIs' datatype='real' name='[Calculation_0166620228988928]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 2] = &apos;Quantity&apos; THEN SUM([Quantity])&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Profit&apos; THEN [Calculation_0986580660813838]&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Revenue&apos; THEN SUM([Calculation_0986580664356881])&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Total Orders&apos; THEN COUNT([Sale_ID])&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Profit Margin&apos; THEN [Calculation_0986580660813838] / SUM([Calculation_0986580664356881])&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Avg Sales Per Order&apos; THEN SUM([Calculation_0986580663074831]) / COUNT([Sale_ID])&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Total Sales&apos; THEN SUM([Calculation_0986580663074831])&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Total Customers&apos; THEN COUNTD([Customer_ID])&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Total Products&apos; THEN COUNTD([Product_ID])&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;Avg Age&apos; THEN AVG([Age])&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Top n Show/Hide' datatype='boolean' name='[Calculation_0166620236763138]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 3]=TRUE' />
      </column>
      <column caption='One' datatype='integer' name='[Calculation_0166620238352387]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Final Cost With Disscount' datatype='real' name='[Calculation_0986580572631042]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Price]-[Discount]' />
      </column>
      <column caption='Avg Sales Per Order' datatype='real' name='[Calculation_0986580634009609]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0986580663074831])/COUNTD([Sale_ID])' />
      </column>
      <column caption='Total Orders' datatype='integer' name='[Calculation_0986580637220874]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Sale_ID])' />
      </column>
      <column caption='Total Cost' datatype='real' name='[Calculation_0986580660363276]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Cost_Price]*[Quantity]' />
      </column>
      <column caption='Profit' datatype='real' name='[Calculation_0986580660813838]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0986580664356881])-SUM([Calculation_0986580660363276])' />
      </column>
      <column caption='Total Sales' datatype='real' name='[Calculation_0986580663074831]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Price]*[Quantity]' />
      </column>
      <column caption='Revenue' datatype='real' name='[Calculation_0986580664356881]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0986580663074831]*(1-[Discount])' />
      </column>
      <column caption='Profit Margin' datatype='real' name='[Calculation_0986580679028754]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0986580660813838]/Sum([Calculation_0986580664356881])' />
      </column>

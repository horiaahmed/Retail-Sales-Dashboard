            <column caption='Total Cost' datatype='real' name='[Calculation_0986580660363276]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Cost_Price]*[Quantity]' />
            </column>
            <column caption='Profit' datatype='real' name='[Calculation_0986580660813838]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_0986580664356881])-SUM([Calculation_0986580660363276])' />
            </column>
            <column caption='Total Sales' datatype='real' name='[Calculation_0986580663074831]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Price]*[Quantity]' />

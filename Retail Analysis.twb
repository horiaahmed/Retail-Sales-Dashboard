            <column caption='Revenue' datatype='real' name='[Calculation_0986580664356881]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_0986580663074831]*(1-[Discount])' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column caption='unit Cost Price' datatype='real' name='[Cost_Price]' role='measure' type='quantitative' />
